# GardenDoctor infrastructure environment contract.
# Copy this file to infra/.env. Never commit the real .env.
# Values below are public local-development placeholders, not production credentials.

# Published host ports
BACKEND_PORT=8080
AI_PORT=8000
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6379
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001

# MySQL and Redis
MYSQL_DATABASE=gardendoctor
MYSQL_USER=gardendoctor
MYSQL_PASSWORD=gardendoctor-local-password
MYSQL_ROOT_PASSWORD=gardendoctor-local-root-password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Backend authentication and external clients
JWT_ACCESS_SECRET=public-local-access-jwt-secret-change-before-any-deployment-2026
JWT_REFRESH_SECRET=public-local-refresh-jwt-secret-change-before-any-deployment-2026
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000

SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=public-local-google-client
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=public-local-google-secret
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_ID=public-local-kakao-client
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_KAKAO_CLIENT_SECRET=public-local-kakao-secret
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_NAVER_CLIENT_ID=public-local-naver-client
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_NAVER_CLIENT_SECRET=public-local-naver-secret

CLOUD_AWS_CREDENTIALS_ACCESS_KEY=public-local-access-key
CLOUD_AWS_CREDENTIALS_SECRET_KEY=public-local-secret-key
CLOUD_AWS_REGION_STATIC=ap-northeast-2
CLOUD_AWS_S3_BUCKET=gardendoctor-local
KAKAO_API_KEY=public-local-kakao-api-key

# Backend mail and outbound-call timeouts
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
SPRING_MAIL_CONNECTION_TIMEOUT_MS=3000
SPRING_MAIL_READ_TIMEOUT_MS=5000
SPRING_MAIL_WRITE_TIMEOUT_MS=5000
PYTHON_CONNECT_TIMEOUT_MS=2000
PYTHON_RESPONSE_TIMEOUT_MS=15000
PYTHON_REQUEST_TIMEOUT_MS=15000

# Backend feature flags and worker tuning
APP_USERPLANT_CARE_SCHEDULER_ENABLED=false
APP_USERPLANT_CARE_SCHEDULER_ZONE=Asia/Seoul
APP_USERPLANT_CARE_SCHEDULER_RESET_CRON=0 0 0 * * *
APP_USERPLANT_CARE_SCHEDULER_DAILY_CRON=0 0 9 * * *
APP_USERPLANT_CARE_SCHEDULER_INCOMPLETE_CRON=0 0 17 * * *
APP_USERPLANT_CARE_SCHEDULER_LOCK_WAIT_SECONDS=0
APP_USERPLANT_CARE_SCHEDULER_BATCH_SIZE=1000

APP_AUTH_LOGIN_RATE_LIMIT_ENABLED=true
APP_AUTH_LOGIN_RATE_LIMIT_MAX_FAILURES=5
APP_AUTH_LOGIN_RATE_LIMIT_FAILURE_WINDOW_SECONDS=900
APP_AUTH_LOGIN_RATE_LIMIT_LOCK_DURATION_SECONDS=900
APP_AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=900
APP_AUTH_PASSWORD_RESET_REQUEST_COOLDOWN_SECONDS=60
APP_AUTH_PASSWORD_RESET_CONFIRM_URL=http://localhost:3000/reset-password

APP_CHAT_DELETION_WORKER_ENABLED=false
APP_CHAT_DELETION_WORKER_FIXED_DELAY_MS=10000
APP_CHAT_DELETION_WORKER_BATCH_SIZE=50
APP_CHAT_DELETION_WORKER_MAX_ATTEMPTS=5
APP_CHAT_DELETION_WORKER_LOCK_TIMEOUT_MINUTES=10
APP_PHOTO_ANALYSIS_REQUEST_COOLDOWN_SECONDS=10

FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_HOST_PATH=/absolute/path/to/firebase-admin.json
APP_FCM_OUTBOX_WORKER_ENABLED=false
APP_FCM_OUTBOX_WORKER_FIXED_DELAY_MS=1000
APP_FCM_OUTBOX_WORKER_BATCH_SIZE=500
APP_FCM_OUTBOX_WORKER_MAX_BATCHES_PER_RUN=20
APP_FCM_OUTBOX_WORKER_MAX_ATTEMPTS=5
APP_FCM_OUTBOX_WORKER_LOCK_TIMEOUT_MINUTES=10

APP_INIT_SEED_DATA_ENABLED=false
APP_SCHEMA_BOOTSTRAP_ENABLED=false
APP_INTEGRITY_IDENTIFIER_REFERENCE_HEALTH_ENABLED=false
APP_INTEGRITY_IDENTIFIER_REFERENCE_MONITOR_ENABLED=false
APP_INTEGRITY_IDENTIFIER_REFERENCE_MONITOR_CRON=0 0 3 * * *
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus
MANAGEMENT_HEALTH_PROBES_ENABLED=true
MANAGEMENT_METRICS_DISTRIBUTION_PERCENTILES_HISTOGRAM_HTTP_SERVER_REQUESTS=true
MANAGEMENT_METRICS_TAGS_APPLICATION=gardendoctor-backend
MANAGEMENT_METRICS_TAGS_ENVIRONMENT=local-compose

# AI runtime and separately distributed read-only assets
AI_DATABASE_URL=sqlite:////data/feedback.db
AI_CORS_ORIGINS=http://localhost
AI_MODEL_DIR=ai_models
AI_VECTOR_INDEX_DIR=embeddings/faiss_index
AI_MODEL_HOST_DIR=../services/ai/ai_models
AI_EMBEDDINGS_HOST_DIR=../services/ai/embeddings
OPENAI_API_KEY=
TAVILY_API_KEY=
NONGSARO_API_KEY=

# Mobile build-time values. Only these keys are copied into app.local.json.
API_BASE_URL=http://127.0.0.1:8080
KAKAO_NATIVE_APP_KEY=
KAKAO_MAP_APP_KEY=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=public-local-grafana-password
MYSQL_EXPORTER_USER=gardendoctor_exporter
MYSQL_EXPORTER_PASSWORD=public-local-exporter-password

# Load testing. The reserved local account must never be a real user.
PERF_BASE_URL=http://backend:8080
PERF_TEST_RUN_ID=local
PERF_RATE=20
PERF_DURATION=30s
PERF_PRE_ALLOCATED_VUS=20
PERF_MAX_VUS=100
PERF_CURSOR_P95_MS=100
PERF_CURSOR_P99_MS=200
PERF_OFFSET_P95_MS=250
PERF_OFFSET_P99_MS=500
PERF_MIN_P95_IMPROVEMENT=3
PERF_MIN_P99_IMPROVEMENT=3
PERF_MAX_BASELINE_REGRESSION_RATIO=1.20
PERF_SPIKE_RATE=100
PERF_SOAK_DURATION=10m
PERF_SATURATION_RATE=1000
PERF_USER_EMAIL=performance@gardendoctor.local
PERF_USER_PASSWORD=PerfTest1!
PERF_USER_NICKNAME=perf-user
PERF_DATASET_SIZE=120000
PERF_DEEP_PAGE=4000
PERF_PAGE_SIZE=20
PERF_CURSOR=
